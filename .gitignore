# ================================ #
# Android & Gradle ignore rules
# ================================ #

# Gradle
.gradle/
build/
**/build/

# Local settings (SDK path, machine-specific)
local.properties

# IntelliJ / Android Studio project files
.idea/
*.iml

# Cache / Generated folders
.cxx/
.externalNativeBuild/
captures/
output.json

# Jetpack Compose cache
.compose-cache/

# OS system files
.DS_Store
Thumbs.db

# Keystore files (important!)
*.jks
*.keystore

# APK / AAB output
*.apk
*.aab

# Misc backups
*.zip

# On-device model artifacts
app/src/main/assets/models/tinyllama/
app/src/main/assets/models/*.onnx
app/src/main/assets/models/*.onnx.data
app/src/main/assets/models/phi3-*.json
app/libs/*.aar
!app/src/main/assets/models/.gitkeep
!app/libs/.gitkeep
